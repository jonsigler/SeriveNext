# Copy to .env and edit as needed

# Database (SQLAlchemy URL). SQLite default; swap to PostgreSQL by setting e.g.:
# DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/serivenext
DATABASE_URL=sqlite:///./serivenext.db

# Session cookie signing key - CHANGE IN PRODUCTION
SECRET_KEY=change-me-to-a-long-random-string

# Agentic AI configuration.
# Leave AI_PROVIDER=rule to use the built-in rule-based agent with no external
# dependencies. Set to "openai" to use any OpenAI-compatible endpoint
# (works with Ollama, LM Studio, llama.cpp server, vLLM, etc.).
AI_PROVIDER=rule

# OpenAI-compatible endpoint (only used if AI_PROVIDER=openai)
# Examples:
#   Ollama:    http://localhost:11434/v1
#   LM Studio: http://localhost:1234/v1
AI_BASE_URL=http://localhost:11434/v1
AI_API_KEY=ollama
AI_MODEL=llama3.1:8b

# How confident the AI must be (0..1) before it auto-resolves a ticket.
AI_AUTO_RESOLVE_THRESHOLD=0.85
